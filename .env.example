YANDEX_API_KEY=your_yandex_api_key_here
YANDEX_FOLDER_ID=your_yandex_folder_id_here

# Отдельный API-ключ для SpeechKit (можно использовать тот же, что и YANDEX_API_KEY)
YANDEX_SPEECHKIT_API_KEY=your_yandex_speechkit_api_key_here

PROXI_API_KEY=your_proxi_api_key_here
PROXI_BASE_URL=https://openai.api.proxyapi.ru/v1

BOT_TOKEN=your_telegram_bot_token_here

# Docker Compose: для образа с Docker Hub (и для docker compose push) укажи свой логин
# DOCKERHUB_IMAGE=your_dockerhub_login/rise-and-shine-bot:latest

# Модель и размер изображения (OpenAI-совместимый image API)
IMAGE_MODEL=gpt-image-1-mini
IMAGE_SIZE=1024x1024
IMAGE_API_TIMEOUT_SECONDS=240

# Yandex GPT: суффикт модели для completion (папка задаётся YANDEX_FOLDER_ID)
YANDEX_COMPLETION_MODEL=yandexgpt-lite/latest

# Лимит интерактивных генераций (/new) на пользователя за сутки UTC; 0 = без лимита
GENERATION_DAILY_LIMIT=5

# Очистка outputs: удалять файлы старше N дней (скрипт cleanup_outputs.py)
OUTPUT_MAX_AGE_DAYS=7

# Обогащение промпта картинки через Yandex GPT (аффирмации → англ. промпт)
LLM_IMAGE_PROMPT_ENABLED=true

# Опционально: путь к ffmpeg (для озвучки с паузами). На Linux обычно не нужен — установи ffmpeg (apt install ffmpeg).

# В Docker задаётся автоматически (не нужно в .env на сервере): BOT_DATA_DIR=/app/data
