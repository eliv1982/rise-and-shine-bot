# Capability-based providers
TEXT_PROVIDER=openai
IMAGE_PROVIDER=openai
TTS_PROVIDER=openai
STT_PROVIDER=openai

OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1

# Database backend:
# - PostgreSQL is used when DATABASE_URL starts with postgres:// or postgresql://
# - SQLite remains the default when DATABASE_URL is absent
DATABASE_URL=
SQLITE_DB_PATH=

# Optional legacy providers
PROXI_API_KEY=
PROXI_BASE_URL=https://openai.api.proxyapi.ru/v1
YANDEX_API_KEY=
YANDEX_FOLDER_ID=
YANDEX_SPEECHKIT_API_KEY=

BOT_TOKEN=your_telegram_bot_token_here

# Docker Compose: для образа с Docker Hub (и для docker compose push) укажи свой логин
# DOCKERHUB_IMAGE=your_dockerhub_login/rise-and-shine-bot:latest

# Legacy image env (kept for backward compatibility)
IMAGE_MODEL=gpt-image-1
IMAGE_SIZE=1024x1024
IMAGE_API_TIMEOUT_SECONDS=240
SHOW_IMAGE_DEBUG=false
SCENE_PLANNER_SHADOW_ENABLED=false
TEXT_PLANNER_SHADOW_ENABLED=false
SCENE_PLANNER_IMAGE_PROMPT_ENABLED=false
TEXT_PLANNER_CONTROLLED_ENABLED=false
TEXT_MEMORY_CONTEXT_ENABLED=false
TEXT_REVIEWER_SHADOW_ENABLED=false
ORCHESTRATOR_SHADOW_ENABLED=false

# Text models
OPENAI_TEXT_MODEL=gpt-4o-mini
PROXI_TEXT_MODEL=gpt-4o-mini
YANDEX_TEXT_MODEL=yandexgpt-lite/latest
# Legacy name kept for backward compatibility:
YANDEX_COMPLETION_MODEL=yandexgpt-lite/latest

# Image models/options
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_IMAGE_SIZE=1024x1024
OPENAI_IMAGE_TIMEOUT_SECONDS=240

PROXI_IMAGE_MODEL=gpt-image-1
PROXI_IMAGE_SIZE=1024x1024
PROXI_IMAGE_TIMEOUT_SECONDS=240

# TTS
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=alloy
OPENAI_TTS_TIMEOUT_SECONDS=240

# STT
OPENAI_STT_MODEL=gpt-4o-mini-transcribe
OPENAI_STT_LANGUAGE=
OPENAI_STT_TIMEOUT_SECONDS=120

YANDEX_TTS_VOICE=oksana
YANDEX_TTS_MODEL=general
YANDEX_TTS_TIMEOUT_SECONDS=60
YANDEX_STT_MODEL=general
YANDEX_STT_LANGUAGE=ru-RU
YANDEX_STT_TIMEOUT_SECONDS=120

# Лимит интерактивных генераций (/new) на пользователя за сутки UTC; 0 = без лимита
DAILY_GENERATION_LIMIT=5
# Backward-compatible legacy name; DAILY_GENERATION_LIMIT has priority if both are set
GENERATION_DAILY_LIMIT=5
# Для ручного тестирования: true = не применять дневной лимит
DISABLE_DAILY_GENERATION_LIMIT=false

# Очистка outputs: удалять файлы старше N дней (скрипт cleanup_outputs.py)
OUTPUT_MAX_AGE_DAYS=7

# Обогащение промпта картинки через Yandex GPT (аффирмации → англ. промпт)
LLM_IMAGE_PROMPT_ENABLED=true

# Опционально: путь к ffmpeg (для озвучки с паузами). На Linux обычно не нужен — установи ffmpeg (apt install ffmpeg).

# В Docker задаётся автоматически (не нужно в .env на сервере): BOT_DATA_DIR=/app/data
