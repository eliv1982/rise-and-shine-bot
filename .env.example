YANDEX_API_KEY=your_yandex_api_key_here
YANDEX_FOLDER_ID=your_yandex_folder_id_here

# Отдельный API-ключ для SpeechKit (можно использовать тот же, что и YANDEX_API_KEY)
YANDEX_SPEECHKIT_API_KEY=your_yandex_speechkit_api_key_here

PROXI_API_KEY=your_proxi_api_key_here
PROXI_BASE_URL=https://openai.api.proxyapi.ru/v1

BOT_TOKEN=your_telegram_bot_token_here

# Опционально: путь к ffmpeg (для озвучки с паузами). На Linux обычно не нужен — установи ffmpeg (apt install ffmpeg).

# В Docker задаётся автоматически (не нужно в .env на сервере): BOT_DATA_DIR=/app/data
