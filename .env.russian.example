TEXT_PROVIDER=yandex
IMAGE_PROVIDER=proxiapi
TTS_PROVIDER=yandex
STT_PROVIDER=yandex

BOT_TOKEN=your_telegram_bot_token_here

# --- Yandex (active in this profile) ---
YANDEX_API_KEY=your_yandex_api_key_here
YANDEX_FOLDER_ID=your_yandex_folder_id_here
YANDEX_SPEECHKIT_API_KEY=your_yandex_speechkit_api_key_here
YANDEX_TEXT_MODEL=yandexgpt-lite/latest
YANDEX_TTS_MODEL=general
YANDEX_TTS_VOICE=oksana
YANDEX_STT_MODEL=general
YANDEX_STT_LANGUAGE=ru-RU
YANDEX_STT_TIMEOUT_SECONDS=120
STT_PREFER_LANGUAGE=ru-RU
ALLOW_CROSS_LANGUAGE_STT_FALLBACK=false

# --- Proxi/OpenAI-compatible image (active in this profile) ---
PROXI_API_KEY=your_proxi_api_key_here
PROXI_BASE_URL=https://openai.api.proxyapi.ru/v1
PROXI_IMAGE_MODEL=gpt-image-1
PROXI_IMAGE_SIZE=1024x1024
PROXI_IMAGE_TIMEOUT_SECONDS=240

